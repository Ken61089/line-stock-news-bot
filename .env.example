# ====== 把這個檔複製成 .env(本機測試用),或在 Zeabur 後台逐項填入環境變數 ======

# --- LINE ---
# LINE Developers 後台 → Messaging API channel 取得
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
# 只允許你本人使用:填你的 LINE user id(傳「id」給機器人可查)。留空 = 不限制(不建議)。
LINE_ALLOWED_USER_ID=

# --- Claude(透過 Zeabur AI Hub,OpenAI 相容)---
OPENAI_BASE_URL=https://hnd1.aihub.zeabur.ai/v1
OPENAI_API_KEY=sk-your-aihub-key
AI_MODEL=claude-sonnet-4-5

# --- Google Sheets ---
# 建議用 SHEET_ID(從試算表網址 /d/ 後面那一長串複製),最穩定
GOOGLE_SHEET_ID=
# 沒填 ID 時,改用試算表「名稱」尋找
GOOGLE_SHEET_TITLE=股票投資大腦資料庫
GOOGLE_SHEET_TAB=新聞時程動態庫

# 部署到雲端時:把整個 service account 的 credentials.json「內容」貼成一行放這裡
# (本機測試可以不填,改成把 credentials.json 放在專案資料夾)
GOOGLE_CREDENTIALS_JSON=

# 服務監聽的埠口(Zeabur 會自動帶入 PORT,本機可不設,預設 8080)
# PORT=8080

# --- 抓連結全文(功能1)---
# 不設也能運作:預設用 trafilatura(免費、零設定)抓新聞正文。
# 若有 Firecrawl 金鑰,會優先用它(更會處理動態/難搞網站)。
# FIRECRAWL_API_KEY=fc-your-key
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# MAX_ARTICLE_CHARS=8000     # 抓回的正文字數上限
# MAX_CONTENT_CHARS=8000     # 送進 AI 分析的內文字數上限

# --- 反向查詢(功能2)---
# QUERY_ROWS_PER_TAB=80      # 每個分頁取最近幾列供查詢
# QUERY_CHAR_BUDGET=15000    # 送進 AI 的資料總字元上限
